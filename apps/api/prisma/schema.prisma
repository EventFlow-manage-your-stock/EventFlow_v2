// =========================================================
// EventFlow - schema.prisma
// =========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// CORE
// =========================================================

model Organizacja {
  id               Int       @id @default(autoincrement())
  nazwa            String    @db.VarChar(255)
  subdomena        String    @unique @db.VarChar(100)
  nip              String?   @unique @db.Char(10)
  regon            String?   @db.Char(14)
  krs              String?   @db.Char(10)
  email            String?   @db.VarChar(150)
  telefon          String?   @db.VarChar(30)
  ulica            String?   @db.VarChar(150)
  kod_pocztowy     String?   @db.VarChar(10)
  miasto           String?   @db.VarChar(100)
  kraj             String    @default("Polska") @db.VarChar(100)
  status           String    @default("aktywna") @db.VarChar(50)
  plan_abonamentu  String?   @db.VarChar(100)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  // Relacje odwrotne
  role                Rola[]
  uzytkownicy         Uzytkownik[]
  uzytkownicy_role    UzytkownikRola[]
  kontrahenci         Kontrahent[]
  kontakty_kontr      KontaktKontrahenta[]
  miejsca             Miejsce[]
  magazyny            Magazyn[]
  kategorie           Kategoria[]
  modele_sprzetu      ModelSprzetu[]
  egzemplarze         Egzemplarz[]
  cenniki             Cennik[]
  ceny_sprzetu        CenaSprzetu[]
  typy_wydarzen       TypWydarzenia[]
  statusy_wydarzen    StatusWydarzenia[]
  wydarzenia          Wydarzenie[]
  typy_etapow         TypEtapu[]
  etapy_wydarzen      EtapWydarzenia[]
  statusy_ofert       StatusOferty[]
  oferty              Oferta[]
  wersje_ofert        WersjaOferty[]
  sekcje_ofert        SekcjaOferty[]
  pozycje_ofert       PozycjaOferty[]
  statusy_wynajmow    StatusWynajmu[]
  wynajmy             Wynajem[]
  pozycje_wynajmu     PozycjaWynajmu[]
  statusy_serwisu     StatusSerwisu[]
  serwisy_sprzetu     SerwisSprzetu[]
  zalaczniki          Zalacznik[]
  logi_zmian          LogZmian[]
  wydarzenia_uzytkownicy WydarzenieUzytkownik[]
  pojazdy             Pojazd[]
  wydarzenia_pojazdy  WydarzeniePojazd[]
  zadania             Zadanie[]
  nieobecnosci        Nieobecnosc[]
  statusy_magazynowe  StatusMagazynowy[]
  statusy_ksiegowe    StatusKsiegowy[]

  @@map("organizacje")
}

model Rola {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(100)
  opis             String?   @db.Text
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  uzytkownicy_role UzytkownikRola[]

  @@unique([id_organizacji, nazwa])
  @@map("role")
}

model Uzytkownik {
  id                        Int       @id @default(autoincrement())
  id_organizacji            Int
  imie                      String    @db.VarChar(100)
  nazwisko                  String    @db.VarChar(100)
  email                     String    @db.VarChar(150)
  telefon                   String?   @db.VarChar(30)
  haslo                     String    @db.VarChar(255)
  avatar                    String?   @db.VarChar(500)
  aktywny                   Boolean   @default(true)
  data_ostatniego_logowania DateTime?
  data_utworzenia           DateTime  @default(now())
  data_aktualizacji         DateTime  @updatedAt
  data_usuniecia            DateTime?

  organizacja               Organizacja @relation(fields: [id_organizacji], references: [id])
  role                      UzytkownikRola[]
  zarzadzane_wydarzenia     Wydarzenie[] @relation("ManagerWydarzenia")
  zarzadzane_oferty         Oferta[]     @relation("ManagerOferty")
  utworzone_wersje_ofert    WersjaOferty[]
  zgloszone_serwisy         SerwisSprzetu[] @relation("ZglosilSerwis")
  rozwiazane_serwisy        SerwisSprzetu[] @relation("RozwiazalSerwis")
  dodane_zalaczniki         Zalacznik[]
  logi_zmian                LogZmian[]
  przypisania_do_wydarzen   WydarzenieUzytkownik[]
  przypisane_zadania        Zadanie[]
  nieobecnosci              Nieobecnosc[]
  utworzone_wydarzenia      Wydarzenie[] @relation("TworcaWydarzenia")

  @@unique([id_organizacji, email])
  @@map("uzytkownicy")
}

model UzytkownikRola {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_uzytkownika   Int
  id_roli          Int
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  uzytkownik       Uzytkownik  @relation(fields: [id_uzytkownika], references: [id])
  rola             Rola        @relation(fields: [id_roli], references: [id])

  @@unique([id_uzytkownika, id_roli])
  @@map("uzytkownicy_role")
}

// =========================================================
// CRM
// =========================================================

model Kontrahent {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(255)
  nazwa_skrocona   String?   @db.VarChar(150)
  nip              String?   @db.Char(10)
  regon            String?   @db.Char(14)
  krs              String?   @db.Char(10)
  ulica            String?   @db.VarChar(150)
  nr_budynku       String?   @db.VarChar(20)
  nr_lokalu        String?   @db.VarChar(20)
  kod_pocztowy     String?   @db.VarChar(10)
  miasto           String?   @db.VarChar(100)
  kraj             String    @default("Polska") @db.VarChar(100)
  email            String?   @db.VarChar(150)
  telefon          String?   @db.VarChar(30)
  uwagi            String?   @db.Text
  zrodlo_danych    String    @default("recznie") @db.VarChar(50)
  data_pobrania_gus DateTime?
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  kontakty         KontaktKontrahenta[]
  wydarzenia       Wydarzenie[]
  oferty           Oferta[]
  wynajmy          Wynajem[]

  @@index([nip])
  @@index([nazwa])
  @@map("kontrahenci")
}

model KontaktKontrahenta {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_kontrahenta   Int
  imie             String?   @db.VarChar(100)
  nazwisko         String?   @db.VarChar(100)
  stanowisko       String?   @db.VarChar(100)
  email            String?   @db.VarChar(150)
  telefon          String?   @db.VarChar(30)
  telefon_2        String?   @db.VarChar(30)
  notatki_wewnetrzne String? @db.Text
  glowny           Boolean   @default(false)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  kontrahent       Kontrahent  @relation(fields: [id_kontrahenta], references: [id])
  wydarzenia       Wydarzenie[]
  oferty           Oferta[]

  @@index([id_kontrahenta])
  @@map("kontakty_kontrahentow")
}

model Miejsce {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(255)
  ulica            String?   @db.VarChar(150)
  kod_pocztowy     String?   @db.VarChar(10)
  miasto           String?   @db.VarChar(100)
  kraj             String    @default("Polska") @db.VarChar(100)
  opis             String?   @db.Text
  notatki_wewnetrzne String? @db.Text
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenia       Wydarzenie[]

  @@map("miejsca")
}

// =========================================================
// MAGAZYN
// =========================================================

model Magazyn {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(100)
  opis             String?   @db.Text
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  egzemplarze      Egzemplarz[]

  @@unique([id_organizacji, nazwa])
  @@map("magazyny")
}

model Kategoria {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_rodzica       Int?
  nazwa            String    @db.VarChar(150)
  opis             String?   @db.Text
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  rodzic           Kategoria?  @relation("KategoriaToKategoria", fields: [id_rodzica], references: [id])
  dzieci           Kategoria[] @relation("KategoriaToKategoria")
  modele_sprzetu   ModelSprzetu[]
  pozycje_ofert    PozycjaOferty[]

  @@index([id_rodzica])
  @@map("kategorie")
}

model ModelSprzetu {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_kategorii     Int?
  nazwa            String    @db.VarChar(200)
  producent        String?   @db.VarChar(100)
  miejsce_w_mag    String?   @db.VarChar(200)
  opis             String?   @db.Text
  notatki_wewnetrzne String? @db.Text
  widoczny_w_ofercie Boolean @default(true)
  widoczny_w_mag   Boolean   @default(true)
  szerokosc        Decimal?  @db.Decimal(10, 2)
  wysokosc         Decimal?  @db.Decimal(10, 2)
  glebokosc        Decimal?  @db.Decimal(10, 2)
  objetosc         Decimal?  @db.Decimal(10, 2)
  waga             Decimal?  @db.Decimal(10, 2)
  wartosc          Decimal?  @db.Decimal(12, 2)
  zdjecie          String?   @db.VarChar(500)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  kategoria        Kategoria?  @relation(fields: [id_kategorii], references: [id])
  egzemplarze      Egzemplarz[]
  ceny             CenaSprzetu[]
  pozycje_ofert    PozycjaOferty[]
  pozycje_wynajmu  PozycjaWynajmu[]
  typ_sprzetu        String    @default("sprzet") @db.VarChar(50) // np. sprzet, opakowanie, zestaw
  ulubiony           Boolean   @default(false)
  udostepniony_crn   Boolean   @default(false) // Udostępnienie w Cross Rental Network
  kod_kreskowy       String?   @db.VarChar(100) // Domyślny SKU modelu
  pobor_pradu        Decimal?  @db.Decimal(10, 2)

  @@index([id_kategorii])
  @@index([nazwa])
  @@map("modele")
}

model Egzemplarz {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_modelu        Int
  id_magazynu      Int?
  nazwa            String?   @db.VarChar(200)
  sn               String?   @db.VarChar(200)
  qr_kod           String?   @db.VarChar(255)
  kod_kreskowy     String?   @db.VarChar(100)
  miejsce_w_mag    String?   @db.VarChar(200)
  id_case          Int?
  id_statusu_egzemplarza Int?
  szerokosc        Decimal?  @db.Decimal(10, 2)
  wysokosc         Decimal?  @db.Decimal(10, 2)
  glebokosc        Decimal?  @db.Decimal(10, 2)
  objetosc         Decimal?  @db.Decimal(10, 2)
  waga             Decimal?  @db.Decimal(10, 2)
  wartosc          Decimal?  @db.Decimal(12, 2)
  notatki_wewnetrzne String? @db.Text
  zdjecie          String?   @db.VarChar(500)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  numer_urzadzenia    String?   @db.VarChar(100)
  data_produkcji      DateTime? @db.Date
  cena_zakupu         Decimal?  @db.Decimal(12, 2)
  pakowany_pojedynczo Boolean   @default(false)
  opis                String?   @db.Text
  status_serwisowy    String    @default("Działa") @db.VarChar(50)

  organizacja      Organizacja   @relation(fields: [id_organizacji], references: [id])
  model            ModelSprzetu  @relation(fields: [id_modelu], references: [id])
  magazyn          Magazyn?      @relation(fields: [id_magazynu], references: [id])
  case             Egzemplarz?   @relation("CaseToEgzemplarz", fields: [id_case], references: [id])
  zawartosc_case   Egzemplarz[]  @relation("CaseToEgzemplarz")
  pozycje_wynajmu  PozycjaWynajmu[]
  serwisy          SerwisSprzetu[]

  @@index([id_modelu])
  @@index([sn])
  @@index([qr_kod])
  @@index([kod_kreskowy])
  @@map("egzemplarze")
}

model Cennik {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  domyslny         Boolean   @default(false)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  ceny_sprzetu     CenaSprzetu[]
  oferty           Oferta[]

  @@unique([id_organizacji, nazwa])
  @@map("cenniki")
}

model CenaSprzetu {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_cennika       Int
  id_modelu        Int
  cena_netto       Decimal   @default(0.00) @db.Decimal(12, 2)
  vat              Decimal   @default(23.00) @db.Decimal(5, 2)
  procent_pierwszego_dnia Decimal @default(100.00) @db.Decimal(6, 2)
  przelicznik_kolejnych_dni Decimal @default(1.00) @db.Decimal(8, 2)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja  @relation(fields: [id_organizacji], references: [id])
  cennik           Cennik       @relation(fields: [id_cennika], references: [id])
  model            ModelSprzetu @relation(fields: [id_modelu], references: [id])
  pozycje_ofert    PozycjaOferty[]

  @@unique([id_cennika, id_modelu])
  @@map("ceny_sprzetu")
}

// =========================================================
// WYDARZENIA
// =========================================================

model TypWydarzenia {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenia       Wydarzenie[]

  @@map("typy_wydarzen")
}

model StatusWydarzenia {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenia       Wydarzenie[]

  @@map("statusy_wydarzen")
}

model Wydarzenie {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_typu_wydarzenia Int?
  id_statusu_wydarzenia Int?
  id_kontrahenta   Int?
  id_kontaktu      Int?
  id_miejsca       Int?
  id_managera      Int?
  nazwa            String    @db.VarChar(255)
  numer            String?   @db.VarChar(100)
  opis             String?   @db.Text
  data_start       DateTime?
  data_koniec      DateTime?
  budzet_netto     Decimal?  @db.Decimal(12, 2)
  budzet_brutto    Decimal?  @db.Decimal(12, 2)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?
  miesiac_ksiegowania     String?  @db.VarChar(20)
  uwagi                   String?  @db.Text
  id_tworcy               Int?
  id_statusu_magazynowego Int?
  id_statusu_ksiegowego   Int?

  organizacja      Organizacja       @relation(fields: [id_organizacji], references: [id])
  typ              TypWydarzenia?    @relation(fields: [id_typu_wydarzenia], references: [id])
  status           StatusWydarzenia? @relation(fields: [id_statusu_wydarzenia], references: [id])
  kontrahent       Kontrahent?       @relation(fields: [id_kontrahenta], references: [id])
  kontakt          KontaktKontrahenta? @relation(fields: [id_kontaktu], references: [id])
  miejsce          Miejsce?          @relation(fields: [id_miejsca], references: [id])
  manager          Uzytkownik?       @relation("ManagerWydarzenia", fields: [id_managera], references: [id])
  
  etapy            EtapWydarzenia[]
  oferty           Oferta[]
  wynajmy          Wynajem[]
  ekipa            WydarzenieUzytkownik[] // Nowa relacja
  pojazdy          WydarzeniePojazd[]     // Nowa relacja
  tworca                  Uzytkownik?       @relation("TworcaWydarzenia", fields: [id_tworcy], references: [id])
  status_magazynowy       StatusMagazynowy? @relation(fields: [id_statusu_magazynowego], references: [id])
  status_ksiegowy         StatusKsiegowy?   @relation(fields: [id_statusu_ksiegowego], references: [id])

  @@index([data_start, data_koniec])
  @@map("wydarzenia")
}

model StatusMagazynowy {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenia       Wydarzenie[]

  @@map("statusy_magazynowe")
}

model StatusKsiegowy {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenia       Wydarzenie[]

  @@map("statusy_ksiegowe")
}

model TypEtapu {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  skrot            String?   @db.VarChar(20)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  etapy            EtapWydarzenia[]

  @@map("typy_etapow")
}

model EtapWydarzenia {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_wydarzenia    Int
  id_typu_etapu    Int?
  nazwa            String    @db.VarChar(150)
  data_start       DateTime
  data_koniec      DateTime
  opis             String?   @db.Text
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenie       Wydarzenie  @relation(fields: [id_wydarzenia], references: [id])
  typ              TypEtapu?   @relation(fields: [id_typu_etapu], references: [id])

  @@index([id_wydarzenia])
  @@map("etapy_wydarzen")
}

// =========================================================
// OFERTY
// =========================================================

model StatusOferty {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  nazwa            String    @db.VarChar(150)
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  oferty           Oferta[]

  @@map("statusy_ofert")
}

model Oferta {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_wydarzenia    Int?
  id_kontrahenta   Int?
  id_kontaktu      Int?
  id_managera      Int?
  id_cennika       Int?
  id_statusu_oferty Int?
  numer            String?   @db.VarChar(100)
  nazwa            String    @db.VarChar(255)
  data_sporzadzenia DateTime? @db.Date
  termin_platnosci_dni Int   @default(14)
  budzet_netto     Decimal?  @db.Decimal(12, 2)
  budzet_brutto    Decimal?  @db.Decimal(12, 2)
  aktualna_wersja  Int       @default(1)
  suma_przed_budzetem_netto Decimal @default(0.00) @db.Decimal(12, 2)
  rabat_budzetowy_netto Decimal @default(0.00) @db.Decimal(12, 2)
  rabat_budzetowy_proc Decimal @default(0.0000) @db.Decimal(8, 4)
  suma_sprzet_netto Decimal  @default(0.00) @db.Decimal(12, 2)
  suma_transport_netto Decimal @default(0.00) @db.Decimal(12, 2)
  suma_obsluga_netto Decimal @default(0.00) @db.Decimal(12, 2)
  suma_nocleg_netto Decimal  @default(0.00) @db.Decimal(12, 2)
  suma_inne_netto  Decimal   @default(0.00) @db.Decimal(12, 2)
  suma_netto       Decimal   @default(0.00) @db.Decimal(12, 2)
  suma_vat         Decimal   @default(0.00) @db.Decimal(12, 2)
  suma_brutto      Decimal   @default(0.00) @db.Decimal(12, 2)
  algorytm_budzetu String    @default("brak") @db.VarChar(50)
  blokada_cen      Boolean   @default(false)
  warunki_zamowienia String? @db.Text
  notatki_wewnetrzne String? @db.Text
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenie       Wydarzenie? @relation(fields: [id_wydarzenia], references: [id])
  kontrahent       Kontrahent? @relation(fields: [id_kontrahenta], references: [id])
  kontakt          KontaktKontrahenta? @relation(fields: [id_kontaktu], references: [id])
  manager          Uzytkownik? @relation("ManagerOferty", fields: [id_managera], references: [id])
  cennik           Cennik?     @relation(fields: [id_cennika], references: [id])
  status           StatusOferty? @relation(fields: [id_statusu_oferty], references: [id])
  wersje           WersjaOferty[]
  wynajmy          Wynajem[]

  @@index([id_wydarzenia])
  @@index([numer])
  @@map("oferty")
}

model WersjaOferty {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_oferty        Int
  numer_wersji     Int
  nazwa            String    @db.VarChar(255)
  powod_zmiany     String?   @db.Text
  suma_netto       Decimal   @default(0.00) @db.Decimal(12, 2)
  suma_vat         Decimal   @default(0.00) @db.Decimal(12, 2)
  suma_brutto      Decimal   @default(0.00) @db.Decimal(12, 2)
  id_uzytkownika_utworzyl Int?
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja @relation(fields: [id_organizacji], references: [id])
  oferta           Oferta      @relation(fields: [id_oferty], references: [id])
  utworzyl         Uzytkownik? @relation(fields: [id_uzytkownika_utworzyl], references: [id])
  sekcje           SekcjaOferty[]
  pozycje          PozycjaOferty[]

  @@unique([id_oferty, numer_wersji])
  @@map("wersje_ofert")
}

model SekcjaOferty {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_wersji_oferty Int
  nazwa            String    @db.VarChar(255)
  opis             String?   @db.Text
  kolor            String?   @db.VarChar(20)
  kolejnosc        Int       @default(0)
  budzet_netto     Decimal?  @db.Decimal(12, 2)
  suma_netto       Decimal   @default(0.00) @db.Decimal(12, 2)
  widoczna_w_pdf   Boolean   @default(true)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja  @relation(fields: [id_organizacji], references: [id])
  wersja           WersjaOferty @relation(fields: [id_wersji_oferty], references: [id])
  pozycje          PozycjaOferty[]

  @@index([id_wersji_oferty])
  @@map("sekcje_oferty")
}

model PozycjaOferty {
  id               Int       @id @default(autoincrement())
  id_organizacji   Int
  id_wersji_oferty Int
  id_sekcji        Int?
  id_kategorii     Int?
  id_modelu        Int?
  id_ceny_sprzetu  Int?
  typ_pozycji      String    @default("sprzet") @db.VarChar(50)
  nazwa            String    @db.VarChar(255)
  opis             String?   @db.Text
  uwagi            String?   @db.Text
  cena_netto       Decimal   @default(0.00) @db.Decimal(12, 2)
  ilosc            Decimal   @default(1.00) @db.Decimal(10, 2)
  dni_pracy        Decimal   @default(1.00) @db.Decimal(10, 2)
  procent_pierwszego_dnia Decimal @default(100.00) @db.Decimal(6, 2)
  przelicznik      Decimal   @default(1.00) @db.Decimal(8, 2)
  rabat_proc       Decimal   @default(0.00) @db.Decimal(6, 2)
  rabat_netto      Decimal   @default(0.00) @db.Decimal(12, 2)
  cena_przed_budzetem_netto Decimal @default(0.00) @db.Decimal(12, 2)
  rabat_budzetowy_netto Decimal @default(0.00) @db.Decimal(12, 2)
  vat              Decimal   @default(23.00) @db.Decimal(5, 2)
  razem_netto      Decimal   @default(0.00) @db.Decimal(12, 2)
  razem_vat        Decimal   @default(0.00) @db.Decimal(12, 2)
  razem_brutto     Decimal   @default(0.00) @db.Decimal(12, 2)
  kolejnosc        Int       @default(0)
  widoczna_w_pdf   Boolean   @default(true)
  zablokowana_przed_budzetem Boolean @default(false)
  aktywny          Boolean   @default(true)
  data_utworzenia  DateTime  @default(now())
  data_aktualizacji DateTime @updatedAt
  data_usuniecia   DateTime?

  organizacja      Organizacja   @relation(fields: [id_organizacji], references: [id])
  wersja           WersjaOferty  @relation(fields: [id_wersji_oferty], references: [id])
  sekcja           SekcjaOferty? @relation(fields: [id_sekcji], references: [id])
  kategoria        Kategoria?    @relation(fields: [id_kategorii], references: [id])
  model            ModelSprzetu? @relation(fields: [id_modelu], references: [id])
  cena             CenaSprzetu?  @relation(fields: [id_ceny_sprzetu], references: [id])

  @@index([id_wersji_oferty])
  @@index([id_sekcji])
  @@map("pozycje_oferty")
}

