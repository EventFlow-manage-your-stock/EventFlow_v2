  user_agent      String?  @db.Text
  data_utworzenia DateTime @default(now())

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  uzytkownik  Uzytkownik? @relation(fields: [id_uzytkownika], references: [id])

  @@index([typ_obiektu, id_obiektu])
  @@index([data_utworzenia])
  @@map("logi_zmian")
}

// =========================================================
// NOWE MODUŁY (DODANE NA BAZIE INTERFEJSU WMS)
// =========================================================

model WydarzenieUzytkownik {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  id_wydarzenia     Int
  id_uzytkownika    Int
  rola_w_wydarzeniu String?   @db.VarChar(100) // np. technik, realizator
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenie  Wydarzenie  @relation(fields: [id_wydarzenia], references: [id])
  uzytkownik  Uzytkownik  @relation(fields: [id_uzytkownika], references: [id])

  @@unique([id_wydarzenia, id_uzytkownika])
  @@map("wydarzenia_uzytkownicy")
}

model Pojazd {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  nazwa             String    @db.VarChar(150)
  nr_rejestracyjny  String    @db.VarChar(50)
  marka             String?   @db.VarChar(100)
  model             String?   @db.VarChar(100)
  rok_produkcji     Int?
  vin               String?   @db.VarChar(50)
  przebieg_km       Int?
  data_przegladu    DateTime? @db.Date
  data_oc           DateTime? @db.Date
  numer_polisy_oc   String?   @db.VarChar(100)
  ubezpieczyciel    String?   @db.VarChar(150)
  ladownosc_kg      Decimal?  @db.Decimal(10, 2)
  objetosc_m3       Decimal?  @db.Decimal(10, 2)
  notatki           String?   @db.Text
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja       Organizacja        @relation(fields: [id_organizacji], references: [id])
  wydarzenia        WydarzeniePojazd[]
  zadania           Zadanie[]
  serwisy_pojazdu   SerwisPojazdu[]
  przeglady_pojazdu PrzegladPojazdu[]

  @@unique([id_organizacji, nr_rejestracyjny])
  @@index([vin])
  @@map("pojazdy")
}

model SerwisPojazdu {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  id_pojazdu        Int
  data_serwisu      DateTime  @db.Date
  przebieg_km       Int?
  opis              String?   @db.Text
  koszt_netto       Decimal?  @db.Decimal(12, 2)
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  pojazd      Pojazd      @relation(fields: [id_pojazdu], references: [id])

  @@index([id_pojazdu])
  @@map("serwisy_pojazdow")
}

model PrzegladPojazdu {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  id_pojazdu        Int
  typ               String    @default("techniczny") @db.VarChar(50)
  data_przegladu    DateTime  @db.Date
  data_nastepna     DateTime? @db.Date
  przebieg_km       Int?
  opis              String?   @db.Text
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  pojazd      Pojazd      @relation(fields: [id_pojazdu], references: [id])

  @@index([id_pojazdu])
  @@map("przeglady_pojazdow")
}

model WydarzeniePojazd {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  id_wydarzenia     Int
  id_pojazdu        Int
  rola_pojazdu      String?   @db.VarChar(100) // np. transport glowny
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  wydarzenie  Wydarzenie  @relation(fields: [id_wydarzenia], references: [id])
  pojazd      Pojazd      @relation(fields: [id_pojazdu], references: [id])

  @@unique([id_wydarzenia, id_pojazdu])
  @@map("wydarzenia_pojazdy")
}

model Zadanie {
  id             Int     @id @default(autoincrement())
  id_organizacji Int
  id_tworcy      Int? // Kto zlecił zadanie
  tytul          String  @db.VarChar(200)
  opis           String? @db.Text
  typ_zadania    String? @db.VarChar(100)
  status         String  @default("nowe") @db.VarChar(50)

  data_start  DateTime?
  data_koniec DateTime?

  szacowany_czas_h      Decimal? @db.Decimal(10, 2)
  szacowana_liczba_osob Int?
  cykl                  String?  @db.VarChar(100) // np. jednorazowe, codzienne

  // Konkretne powiązania z modułami
  id_wydarzenia  Int?
  id_kontrahenta Int?
  id_egzemplarza Int?
  id_pojazdu     Int?

  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  tworca      Uzytkownik? @relation("ZlecajacyZadanie", fields: [id_tworcy], references: [id])

  // Relacje
  wydarzenie Wydarzenie? @relation(fields: [id_wydarzenia], references: [id])
  kontrahent Kontrahent? @relation(fields: [id_kontrahenta], references: [id])
  pojazd     Pojazd?     @relation(fields: [id_pojazdu], references: [id])
  egzemplarz Egzemplarz? @relation(fields: [id_egzemplarza], references: [id]) // Dodano poprawną relację sprzętu

  przypisani_uzytkownicy ZadanieUzytkownik[]

  @@map("zadania")
}

model ZadanieUzytkownik {
  id              Int      @id @default(autoincrement())
  id_organizacji  Int
  id_zadania      Int
  id_uzytkownika  Int
  aktywny         Boolean  @default(true)
  data_utworzenia DateTime @default(now())

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  zadanie     Zadanie     @relation(fields: [id_zadania], references: [id], onDelete: Cascade)
  uzytkownik  Uzytkownik  @relation(fields: [id_uzytkownika], references: [id])

  @@unique([id_zadania, id_uzytkownika])
  @@map("zadania_uzytkownicy")
}

model Nieobecnosc {
  id                Int       @id @default(autoincrement())
  id_organizacji    Int
  id_uzytkownika    Int
  typ               String    @db.VarChar(50) // np. urlop, L4
  data_od           DateTime
  data_do           DateTime
  opis              String?   @db.Text
  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  uzytkownik  Uzytkownik  @relation(fields: [id_uzytkownika], references: [id])

  @@map("nieobecnosci")
}

model Zapytanie {
  id             Int  @id @default(autoincrement())
  id_organizacji Int
  id_tworcy      Int?
  id_kontrahenta Int?

  tytul             String  @db.VarChar(255)
  kontrahent_reczny String? @db.VarChar(255) // Gdy zapytanie jest od klienta spoza bazy
  opis              String? @db.Text
  status            String  @default("nowe") @db.VarChar(50) // nowe, w_wycenie, wyslana, zaakceptowane, odrzucone

  aktywny           Boolean   @default(true)
  data_utworzenia   DateTime  @default(now())
  data_aktualizacji DateTime  @updatedAt
  data_usuniecia    DateTime?

  organizacja Organizacja @relation(fields: [id_organizacji], references: [id])
  tworca      Uzytkownik? @relation("TworcaZapytania", fields: [id_tworcy], references: [id])
  kontrahent  Kontrahent? @relation(fields: [id_kontrahenta], references: [id])

  @@index([status])
  @@map("zapytania")
}
