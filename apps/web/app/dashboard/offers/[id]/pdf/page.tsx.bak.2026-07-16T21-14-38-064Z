          grid-template-columns: 1.4fr 0.8fr;
          gap: 18px;
          border-radius: 22px;
          background: linear-gradient(135deg, #082429 0%, #0e4b56 55%, #0891b2 100%);
          color: white;
          padding: 26px;
          overflow: hidden;
          position: relative;
        }

