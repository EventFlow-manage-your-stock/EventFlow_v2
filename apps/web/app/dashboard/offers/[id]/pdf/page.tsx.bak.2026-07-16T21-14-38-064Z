    return <div className="pdf-loading">Ładowanie oferty...</div>;
  }

  if (error) {
    return <div className="pdf-loading text-red-700">{error}</div>;
  }

  if (!offer) {
    return <div className="pdf-loading">Nie znaleziono oferty.</div>;
  }

  const version = offer.wersje?.[0];
