            <div>
              <img className="pdf-logo" src="/eventflow-logo-sidebar.svg" alt="EventFlow" />
              <p className="pdf-kicker">Oferta dla klienta</p>
              <h1>{text(offer.nazwa, 'Oferta')}</h1>
              <p className="pdf-subtitle">
                Profesjonalna obsługa techniczna, sprzęt AV, multimedia, transport i wsparcie realizacyjne wydarzenia.
              </p>
            </div>

            <dl className="pdf-number-box">
              <dt>Numer oferty</dt>
              <dd>{text(offer.numer)}</dd>
              <dt>Data wystawienia</dt>
              <dd>{date(issueDate)}</dd>
              <dt>Wersja</dt>
              <dd>{version?.numer_wersji ? `v${version.numer_wersji}` : 'v1'}</dd>
              <dt>Termin płatności</dt>
              <dd>{offer.termin_platnosci_dni || 14} dni</dd>
            </dl>
          </header>

          <section className="pdf-grid">
            <div className="pdf-card">
              <h2>Klient</h2>
              <p><strong>{text(client?.nazwa)}</strong></p>
              {client?.nip && <p>NIP: {client.nip}</p>}
              {client?.adres && <p>{client.adres}</p>}
              {client?.email && <p>{client.email}</p>}
            </div>

            <div className="pdf-card">
              <h2>Wydarzenie</h2>
              <p><strong>{text(event?.nazwa)}</strong></p>
              <p>Start: {date(event?.data_start, true)}</p>
              <p>Koniec: {date(event?.data_koniec, true)}</p>
              <p>Miejsce: {text(event?.miejsce?.nazwa || event?.miejsce_reczne)}</p>
            </div>

            <div className="pdf-card">
              <h2>Podsumowanie</h2>
              <p>Netto: <strong>{money(summary.netto)}</strong></p>
              <p>VAT: <strong>{money(summary.vat)}</strong></p>
              <p>Brutto: <strong>{money(summary.brutto)}</strong></p>
              {asNumber(offer.rabat_budzetowy_netto) > 0 && (
                <p>Rabat budżetowy: <strong>{money(offer.rabat_budzetowy_netto)}</strong></p>
              )}
            </div>
          </section>

          {sections.map((section: any) => (
            <section className="pdf-section" key={section.id || section.nazwa}>
              <div className="pdf-section-header">
                <div>
                  <h2>{text(section.nazwa, 'Sekcja')}</h2>
                  {section.opis && <p>{section.opis}</p>}
