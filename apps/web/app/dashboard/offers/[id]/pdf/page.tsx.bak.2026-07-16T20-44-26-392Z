'use client';
import { useEffect, useMemo, useState } from 'react';
import { useParams } from 'next/navigation';
import { api } from '../../../../../lib/api';
import { Button } from '../../../../../components/ProductUI';

function money(v:any){return `${Number(v||0).toLocaleString('pl-PL',{minimumFractionDigits:2,maximumFractionDigits:2})} zł`}
function calc(p:any){const cena=Number(p.cena_netto||0), ilosc=Number(p.ilosc||1), dni=Number(p.dni_pracy||1), rabat=Number(p.rabat_proc||0); return cena*ilosc*dni*(1-rabat/100)}

export default function OfferPdfPage(){
  const { id }=useParams(); const [offer,setOffer]=useState<any>(null);
  useEffect(()=>{api.get(`/api/oferty/${id}`).then(r=>setOffer(r.data))},[id]);
  const sections=offer?.wersje?.[0]?.sekcje||[];
  const summary=useMemo(()=>{const positions=sections.flatMap((s:any)=>s.pozycje||[]); const netto=positions.reduce((a:number,p:any)=>a+Number(p.razem_netto||calc(p)),0); return {netto,vat:netto*.23,brutto:netto*1.23}},[sections]);
  if(!offer) return <p className="p-10 font-bold">Ładowanie PDF...</p>;
  return <div className="min-h-screen bg-slate-100 p-6 print:bg-white print:p-0"><div className="mx-auto mb-4 flex max-w-[900px] justify-end print:hidden"><Button onClick={()=>window.print()}>Drukuj / zapisz jako PDF</Button></div><main className="mx-auto max-w-[900px] bg-white p-10 text-slate-900 shadow-xl print:shadow-none"><style jsx global>{`@media print{body{background:white}.print\\:hidden{display:none!important}@page{size:A4;margin:12mm}}`}</style><header className="mb-10 grid grid-cols-2 gap-8"><div><img src="/eventflow-logo.svg" alt="EventFlow" className="mb-6 h-16"/><p className="text-sm font-bold">EventFlow / Pixel Multimedia</p><p className="text-xs text-slate-500">Oferta wygenerowana z systemu EventFlow</p></div><div className="text-right"><h1 className="text-2xl font-black">{offer.nazwa}</h1><p className="mt-2 text-sm">Numer: <b>{offer.numer || '-'}</b></p><p className="text-sm">Data: <b>{offer.data_sporzadzenia ? new Date(offer.data_sporzadzenia).toLocaleDateString('pl-PL') : new Date().toLocaleDateString('pl-PL')}</b></p></div></header><section className="mb-8 grid grid-cols-2 gap-8 text-sm"><div><h2 className="mb-2 border-b pb-1 font-black uppercase text-slate-500">Klient</h2><p className="font-black">{offer.kontrahent?.nazwa || '-'}</p><p>{offer.kontrahent?.nip ? `NIP: ${offer.kontrahent.nip}` : ''}</p></div><div><h2 className="mb-2 border-b pb-1 font-black uppercase text-slate-500">Wydarzenie</h2><p className="font-black">{offer.wydarzenie?.nazwa || '-'}</p><p>{offer.wydarzenie?.data_start ? new Date(offer.wydarzenie.data_start).toLocaleString('pl-PL') : ''}</p></div></section>{sections.map((section:any)=><section key={section.id} className="mb-7 break-inside-avoid"><h2 className="mb-2 rounded bg-orange-400 px-3 py-2 text-sm font-black text-white">{section.nazwa}</h2><table className="w-full border-collapse text-xs"><thead><tr className="bg-slate-100 text-left"><th className="p-2">Nazwa</th><th className="p-2">Opis</th><th className="p-2 text-right">Cena</th><th className="p-2 text-right">Liczba</th><th className="p-2 text-right">Rabat%</th><th className="p-2 text-right">Dni</th><th className="p-2 text-right">Razem netto</th></tr></thead><tbody>{(section.pozycje||[]).map((p:any)=><tr key={p.id} className="border-b"><td className="p-2 font-bold">{p.nazwa}</td><td className="p-2 text-slate-500">{p.opis||''}</td><td className="p-2 text-right">{money(p.cena_netto)}</td><td className="p-2 text-right">{p.ilosc}</td><td className="p-2 text-right">{p.rabat_proc}%</td><td className="p-2 text-right">{p.dni_pracy}</td><td className="p-2 text-right font-black">{money(p.razem_netto||calc(p))}</td></tr>)}</tbody><tfoot><tr><td colSpan={6} className="p-2 text-right font-black">Łącznie {section.nazwa}</td><td className="p-2 text-right font-black">{money((section.pozycje||[]).reduce((a:number,p:any)=>a+Number(p.razem_netto||calc(p)),0))}</td></tr></tfoot></table></section>)}<section className="mt-10 ml-auto w-[320px] rounded-xl border p-4 text-sm"><p className="flex justify-between"><span>Netto:</span><b>{money(summary.netto)}</b></p><p className="flex justify-between"><span>VAT:</span><b>{money(summary.vat)}</b></p><p className="mt-2 flex justify-between border-t pt-2 text-lg"><span>Brutto:</span><b>{money(summary.brutto)}</b></p></section></main></div>
}
